# Backend configuration. Copy to `.env` for local use, or set these as environment
# variables in production. All names are prefixed with VCS_.

# development | production. In production, unsafe config fails fast at startup.
VCS_ENVIRONMENT=development

# Database. SQLite locally; a Postgres URL in production (postgres:// is normalized).
# VCS_DATABASE_URL=postgres://user:password@host:5432/vcs
VCS_DATABASE_URL=sqlite:///./vcs.db

# Auth. MUST be a strong random value in production (e.g. `openssl rand -hex 32`).
VCS_JWT_SECRET=dev-secret-change-me-in-production-0123456789

# CORS. Comma-separated frontend origins. Required in production.
# VCS_CORS_ORIGINS=https://vcs-frontend.onrender.com
VCS_CORS_ORIGINS=

# Worker mode: thread (single-node dev) | inline (tests) | external (prod worker process).
VCS_WORKER_MODE=thread
VCS_WORKER_POLL_SECONDS=1.0
VCS_BATCH_STEPS=10
VCS_FRAME_STRIDE=1

# AI copilot. Provide a key (or use `ant auth login`) to enable it.
# ANTHROPIC_API_KEY=sk-ant-...
VCS_AI_MODEL=claude-opus-4-8
# VCS_OPENAI_MODEL=            # set (and OPENAI_API_KEY) to enable the OpenAI fallback
